Production 1 us - NPT - ACO2-ARG2 complex
 &cntrl
  imin=0, irest=1, ntx=5,
  nstlim=500000000, dt=0.002,        ! 5e8 steps = 1000 ns (1 us)
  ntpr=25000, ntwx=25000, ntwr=250000, ioutfm=1,
  cut=10.0, ntb=2, ntp=1, barostat=1,
  taup=2.0, ntt=3, gamma_ln=2.0,
  temp0=300.0, iwrap=1, nmropt=1,
  ntc=2, ntf=2,                      ! SHAKE on bonds involving H
 /
! Distance restraints on the [4Fe-4S] cluster (required by nmropt=1)
 &wt type='END' /
DISANG=disang.rest
LISTOUT=POUT
